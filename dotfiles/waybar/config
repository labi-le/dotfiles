{
  "layer": "top",
  "position": "top",
  "height": 16,
  "width": 10,
  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "memory",
    "cpu",
    "pulseaudio",
    "backlight",
    "custom/keyboard-layout",
    "battery",
    "tray"
  ],
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ’Ś¦",
    "format-plugged": "{capacity}% ’ć”",
    "###format-good": "",
    "###format-full": "",
    "format-icons": [
      "’ēä",
      "’ēā",
      "’ēé",
      "’ēü",
      "’ēĆ"
    ]
  },
  "clock": {
    "interval": 10,
    "format-alt": "{:%e %b %Y}",
    "format": "{:%H:%M}",
    "tooltip-format": "{:%e %B %Y}"
  },
  "custom/weather": {
    "return-type" : "json",
    "interval": 18000,
    "exec": "~/.config/waybar/scripts/weather.sh Saint-Petersburg",
    "format": "weather {}"
  },
  "cpu": {
    "interval": 5,
    "format": "cpu {usage}%",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click": "kitty -e 'htop'"
  },
  "custom/keyboard-layout": {
    "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
    "interval": 1,
    "format": "{}",
    "signal": 1,
    "tooltip": false
  },
  "memory": {
    "interval": 5,
    "format": "ram {}%",
    "on-click": "kitty -e 'htop'",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "network": {
    "interval": 5,
    "format-wifi": "’ć½  {essid} ({signalStrength}%)",
    "format-ethernet": "’ā¼  {ifname}: {ipaddr}/{cidr}",
    "format-disconnected": "ŌÜĀ  Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}",
    "on-click": "exec nm-connection-editor"
  },
  "network#vpn": {
    "interface": "tun0",
    "format": "’ĆÆ  {essid} ({signalStrength}%)",
    "format-disconnected": "ŌÜĀ  Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
  },
  "sway/mode": {
    "format": "{}",
    "tooltip": false
  },
  "sway/window": {
    "format": "{}",
    "max-length": 120
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "disable-markup": false,
    "all-outputs": true,
    "format": "  {icon}  ",
    "format-icons": {
      "1": "cmd",
      "2": "dev",
      "3": "browser",
      "4": "social",
      "5": "file",
      "6": "game",
      "7": "work",
      "8": "private"
    }
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "vol {volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} ’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon} ’Ŗö {format_source}",
    "format-muted": "vol {format_source}",
    "format-source": "{volume}%",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’¤Ŗ",
      "hands-free": "’Łŗ",
      "headset": " ’¤Ź ",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣"
    },
    "on-click": "pavucontrol",
    "on-scroll-up": "pamixer -ui 2",
    "on-scroll-down": "pamixer -ud 2"
  },
  "tray": {
    "icon-size": 22,
    "spacing": 10
  },
  "backlight": {
    "format": "backlight {percent}%",
    "on-scroll-down": "brightnessctl -c backlight set 1%-",
    "on-scroll-up": "brightnessctl -c backlight set +1%"
  }
}
